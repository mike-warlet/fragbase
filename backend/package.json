{
  "name": "fragbase-backend",
  "version": "1.0.0",
  "description": "FragBase API - Cloudflare Workers backend",
  "main": "worker.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create fragbase",
    "db:migrate": "wrangler d1 execute fragbase --file=../docs/db-schema.sql",
    "db:local": "wrangler d1 execute fragbase --local --file=../docs/db-schema.sql"
  },
  "dependencies": {
    "@tsndr/cloudflare-worker-jwt": "^2.4.2"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
